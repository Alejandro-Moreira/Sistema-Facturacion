<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración — Sistema de Facturación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

    <!-- ── Barra de navegación ──────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-receipt-cutoff"></i>
                Sistema de Facturación
            </a>
            <div class="d-flex gap-2">
                <a href="/" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-house-fill"></i>
                    <span class="d-none d-sm-inline">Inicio</span>
                </a>
                <a href="/clientes" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-people"></i>
                    <span class="d-none d-sm-inline">Clientes</span>
                </a>
                <a href="/productos" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-box"></i>
                    <span class="d-none d-sm-inline">Productos</span>
                </a>
                <a href="/ventas" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-receipt"></i>
                    <span class="d-none d-sm-inline">Ventas</span>
                </a>
            </div>
        </div>
    </nav>

    <!-- ── Contenido principal ──────────────────────────────────── -->
    <div class="container">

        <!-- Encabezado de sección -->
        <div class="d-flex align-items-center mb-4">
            <i class="bi bi-gear-fill fs-3 me-2 text-primary"></i>
            <h4 class="mb-0 fw-bold">Configuración de Factura</h4>
        </div>

        <!-- Mensajes de feedback (si los hay) -->
        <% if (typeof mensaje !== 'undefined' && mensaje) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><%= mensaje %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <form action="/configuracion" method="POST" enctype="multipart/form-data">

            <!-- ── Datos del negocio ──────────────────────────── -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-building me-2"></i>Datos del Negocio
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nombre del Negocio <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="nombre_negocio"
                                   value="<%= config.nombre_negocio || '' %>"
                                   placeholder="Ej: ECL FRUVER" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">NIT / RUC</label>
                            <input type="text" class="form-control" name="nit"
                                   value="<%= config.nit || '' %>"
                                   placeholder="Ej: 1234567890001">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Dirección</label>
                            <input type="text" class="form-control" name="direccion"
                                   value="<%= config.direccion || '' %>"
                                   placeholder="Ej: Av. Principal 123">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Teléfono</label>
                            <input type="text" class="form-control" name="telefono"
                                   value="<%= config.telefono || '' %>"
                                   placeholder="Ej: 0999999999">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Logo del Negocio</label>
                            <input type="file" class="form-control" name="logo" accept="image/*">
                            <% if (config.logo_src) { %>
                                <div class="mt-2">
                                    <small class="text-muted">Logo actual:</small><br>
                                    <img src="<%= config.logo_src %>" alt="Logo actual"
                                         class="mt-1 rounded border" style="max-width:180px; max-height:80px; object-fit:contain;">
                                </div>
                            <% } %>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">QR para Transferencias</label>
                            <input type="file" class="form-control" name="qr" accept="image/*">
                            <% if (config.qr_src) { %>
                                <div class="mt-2">
                                    <small class="text-muted">QR actual:</small><br>
                                    <img src="<%= config.qr_src %>" alt="QR actual"
                                         class="mt-1 rounded border" style="max-width:120px; max-height:120px; object-fit:contain;">
                                </div>
                            <% } %>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Pie de Página</label>
                            <textarea class="form-control" name="pie_pagina" rows="3"
                                      placeholder="Ej: ¡Gracias por su compra! • www.miweb.com"><%= config.pie_pagina || '' %></textarea>
                            <small class="text-muted">Texto que aparece al final de cada factura impresa.</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Formato de impresión ───────────────────────── -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-printer me-2"></i>Formato de Impresión
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Ancho del Papel (mm)</label>
                            <input type="number" class="form-control" name="ancho_papel"
                                   value="<%= config.ancho_papel || 80 %>" min="58" max="80">
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Recomendado: 80 mm para impresoras de punto de venta estándar.
                            </small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Tamaño de Fuente</label>
                            <select class="form-select" name="font_size">
                                <option value="1" <%= (config.font_size || 1) == 1 ? 'selected' : '' %>>Normal</option>
                                <option value="2" <%= (config.font_size || 1) == 2 ? 'selected' : '' %>>Grande</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Acciones ──────────────────────────────────── -->
            <div class="d-flex gap-2 mb-5">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save me-1"></i>Guardar Configuración
                </button>
                <a href="/" class="btn btn-outline-secondary px-3">
                    <i class="bi bi-arrow-left me-1"></i>Volver
                </a>
            </div>

        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <% if (flash_success && flash_success.length > 0) { %>
    <script>
        // Use JSON.stringify to safely embed the message — avoids XSS in script context
        var _flashMsg = <%- JSON.stringify(flash_success[0]) %>;
        Swal.fire({ icon: 'success', title: _flashMsg, toast: true,
            position: 'top-end', showConfirmButton: false, timer: 2500, timerProgressBar: true });
    </script>
    <% } %>
</body>
</html>
