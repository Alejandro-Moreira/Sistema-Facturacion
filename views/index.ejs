<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Facturación</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        /* ── Wizard Steps ── */
        .step-indicator {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            margin-bottom: 2rem;
        }
        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            flex: 1;
            max-width: 180px;
        }
        .step-circle {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: #dee2e6;
            color: #6c757d;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            font-weight: 700;
            border: 3px solid #dee2e6;
            transition: all 0.3s ease;
            z-index: 2;
        }
        .step-item.active .step-circle {
            background: #0d6efd;
            color: white;
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13,110,253,0.2);
        }
        .step-item.completed .step-circle {
            background: #198754;
            color: white;
            border-color: #198754;
        }
        .step-label {
            font-size: 0.8rem;
            color: #6c757d;
            margin-top: 0.4rem;
            font-weight: 500;
            text-align: center;
        }
        .step-item.active .step-label { color: #0d6efd; font-weight: 700; }
        .step-item.completed .step-label { color: #198754; }
        .step-connector {
            flex: 1;
            height: 3px;
            background: #dee2e6;
            margin-top: -22px;
            margin-bottom: 28px;
            transition: background 0.3s ease;
        }
        .step-connector.completed { background: #198754; }

        /* ── Product dropdown ── */
        .search-dropdown {
            position: absolute;
            top: 100%;
            left: 0; right: 0;
            z-index: 1050;
            background: white;
            border: 1px solid #dee2e6;
            border-radius: 0.5rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            max-height: 280px;
            overflow-y: auto;
        }
        .search-dropdown .dropdown-item {
            padding: 0.6rem 1rem;
            cursor: pointer;
            border-bottom: 1px solid #f8f9fa;
        }
        .search-dropdown .dropdown-item:last-child { border-bottom: none; }
        .search-dropdown .dropdown-item:hover { background: #f0f4ff; }
        .search-container { position: relative; }

        /* ── Step panels ── */
        .step-panel { display: none; }
        .step-panel.active { display: block; }

        /* ── Product table ── */
        #tablaProductos tbody tr td { vertical-align: middle; }

        /* ── Floating total ── */
        .floating-total {
            position: fixed;
            bottom: 1.5rem;
            left: 1.5rem;
            z-index: 1000;
            background: #2c3e50;
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 2rem;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            font-size: 1.1rem;
        }

        /* ── Summary card ── */
        .summary-section { background: #f8f9fa; border-radius: 0.5rem; padding: 1rem; }

        footer { border-top: 1px solid rgba(255,255,255,0.1); margin-top: 5rem; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-receipt-cutoff"></i>
                Sistema de Facturación
            </a>
            <div class="d-flex gap-2">
                <a href="/ventas" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-receipt"></i>
                    <span class="d-none d-sm-inline">Ventas</span>
                </a>
                <a href="/productos" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-box"></i>
                    <span class="d-none d-sm-inline">Productos</span>
                </a>
                <a href="/clientes" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-people"></i>
                    <span class="d-none d-sm-inline">Clientes</span>
                </a>
                <a href="/configuracion" class="btn btn-outline-light nav-btn">
                    <i class="bi bi-gear"></i>
                    <span class="d-none d-sm-inline">Configuración</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="container pb-5">

        <!-- Step Indicator -->
        <div class="step-indicator">
            <div class="step-item active" id="step-dot-1">
                <div class="step-circle"><i class="bi bi-box-seam"></i></div>
                <div class="step-label">Productos</div>
            </div>
            <div class="step-connector" id="connector-1"></div>
            <div class="step-item" id="step-dot-2">
                <div class="step-circle"><i class="bi bi-person"></i></div>
                <div class="step-label">Cliente</div>
            </div>
            <div class="step-connector" id="connector-2"></div>
            <div class="step-item" id="step-dot-3">
                <div class="step-circle"><i class="bi bi-receipt"></i></div>
                <div class="step-label">Factura</div>
            </div>
        </div>

        <!-- ══════════════ STEP 1: PRODUCTS ══════════════ -->
        <div class="step-panel active" id="panel-step-1">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-box-seam me-2"></i>
                    <strong>Paso 1 — Agregar Productos</strong>
                    <small class="text-muted ms-2">Busca productos de la base de datos</small>
                </div>
                <div class="card-body">
                    <!-- Product Search Row -->
                    <div class="row g-2 mb-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Buscar Producto <small class="text-muted">(nombre o código)</small></label>
                            <div class="search-container">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                                    <input type="text" id="buscarProducto" class="form-control"
                                           placeholder="Escriba para buscar..." autocomplete="off">
                                </div>
                                <div id="dropdownProductos" class="search-dropdown" style="display:none;"></div>
                                <input type="hidden" id="producto_id">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold">Unidad</label>
                            <select id="unidadMedida" class="form-select">
                                <option value="UND">UND</option>
                                <option value="CAJA">CAJA</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold">Cantidad</label>
                            <input type="number" id="cantidad" class="form-control" placeholder="0.00" step="0.01" min="0.01">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold">Precio Unit.</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" id="precioUnitario" class="form-control" placeholder="0.00" step="0.01" min="0.01">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button id="btnAgregarProducto" class="btn btn-success w-100" disabled>
                                <i class="bi bi-plus-lg me-1"></i>Agregar
                            </button>
                        </div>
                    </div>

                    <!-- Selected product info badge -->
                    <div id="productoSeleccionadoInfo" class="alert alert-info py-2 d-none">
                        <i class="bi bi-box me-2"></i>
                        <strong id="productoNombreInfo"></strong>
                        <span class="ms-3 text-muted" id="productoPreciosInfo"></span>
                    </div>

                    <!-- Products Table -->
                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="tablaProductos">
                            <thead class="table-light">
                                <tr>
                                    <th>Código</th>
                                    <th>Producto</th>
                                    <th class="text-center">Cantidad</th>
                                    <th class="text-center">Unidad</th>
                                    <th class="text-end">Precio Unit.</th>
                                    <th class="text-end">Subtotal</th>
                                    <th class="text-center">Quitar</th>
                                </tr>
                            </thead>
                            <tbody id="productosBody">
                                <tr id="filaVacia">
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="bi bi-cart h4 d-block mb-1"></i>
                                        Aún no ha agregado productos
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td colspan="5" class="text-end">Total:</td>
                                    <td class="text-end" id="totalPaso1">$0.00</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-end gap-2">
                    <button class="btn btn-outline-secondary btn-sm" id="btnLimpiarProductos">
                        <i class="bi bi-arrow-clockwise me-1"></i>Limpiar todo
                    </button>
                    <button class="btn btn-primary" id="btnSiguienteCliente" disabled>
                        Siguiente: Datos del Cliente <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- ══════════════ STEP 2: CUSTOMER ══════════════ -->
        <div class="step-panel" id="panel-step-2">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-person-fill me-2"></i>
                    <strong>Paso 2 — Datos del Cliente</strong>
                    <small class="text-muted ms-2">Busca clientes existentes o registra uno nuevo</small>
                </div>
                <div class="card-body">
                    <!-- Customer Search -->
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Buscar Cliente <small class="text-muted">(nombre, cédula o teléfono)</small></label>
                            <div class="search-container">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                                    <input type="text" id="buscarCliente" class="form-control"
                                           placeholder="Escriba para buscar cliente..." autocomplete="off">
                                    <button class="btn btn-outline-secondary" id="btnNuevoCliente" type="button"
                                            data-bs-toggle="tooltip" title="Registrar nuevo cliente">
                                        <i class="bi bi-person-plus"></i>
                                    </button>
                                </div>
                                <div id="dropdownClientes" class="search-dropdown" style="display:none;"></div>
                                <input type="hidden" id="cliente_id">
                            </div>
                        </div>
                    </div>

                    <!-- Customer Info Card (auto-populated from DB) -->
                    <div id="infoClienteCard" class="d-none">
                        <div class="alert alert-success">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-2"><i class="bi bi-person-check-fill me-2"></i>Cliente Seleccionado</h6>
                                    <div class="row g-2">
                                        <div class="col-sm-4">
                                            <small class="text-muted d-block">Nombre</small>
                                            <strong id="infoNombre">—</strong>
                                        </div>
                                        <div class="col-sm-4">
                                            <small class="text-muted d-block">Cédula / RUC</small>
                                            <strong id="infoCedula">—</strong>
                                        </div>
                                        <div class="col-sm-4">
                                            <small class="text-muted d-block">Teléfono</small>
                                            <strong id="infoTelefono">—</strong>
                                        </div>
                                        <div class="col-sm-8 mt-1">
                                            <small class="text-muted d-block">Dirección</small>
                                            <strong id="infoDireccion">—</strong>
                                        </div>
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-danger ms-2" id="btnCambiarCliente">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- "No client" shortcut -->
                    <div id="sinClienteOpt" class="mt-2">
                        <button class="btn btn-outline-warning btn-sm" id="btnClienteDesconocido">
                            <i class="bi bi-question-circle me-1"></i>Continuar sin cliente (Desconocido)
                        </button>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between gap-2">
                    <button class="btn btn-outline-secondary" id="btnVolverProductos">
                        <i class="bi bi-arrow-left me-1"></i>Volver a Productos
                    </button>
                    <button class="btn btn-primary" id="btnSiguienteFactura" disabled>
                        Siguiente: Generar Factura <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- ══════════════ STEP 3: INVOICE SUMMARY ══════════════ -->
        <div class="step-panel" id="panel-step-3">
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-receipt-cutoff me-2"></i>
                    <strong>Paso 3 — Resumen y Generación de Factura</strong>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <!-- Products Summary -->
                        <div class="col-md-7">
                            <div class="summary-section h-100">
                                <h6 class="fw-bold mb-3"><i class="bi bi-box-seam me-2"></i>Productos</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Producto</th>
                                                <th class="text-center">Cant.</th>
                                                <th class="text-center">Unid.</th>
                                                <th class="text-end">P.Unit.</th>
                                                <th class="text-end">Subtotal</th>
                                            </tr>
                                        </thead>
                                        <tbody id="resumenProductosBody"></tbody>
                                        <tfoot class="table-light fw-bold">
                                            <tr>
                                                <td colspan="4" class="text-end">Total:</td>
                                                <td class="text-end" id="resumenTotal">$0.00</td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Customer + Payment Summary -->
                        <div class="col-md-5">
                            <div class="summary-section mb-3">
                                <h6 class="fw-bold mb-2"><i class="bi bi-person me-2"></i>Cliente</h6>
                                <div id="resumenCliente">—</div>
                            </div>

                            <div class="summary-section">
                                <h6 class="fw-bold mb-2"><i class="bi bi-credit-card me-2"></i>Forma de Pago</h6>
                                <select id="formaPago" class="form-select">
                                    <option value="efectivo">Efectivo</option>
                                    <option value="transferencia">Transferencia</option>
                                </select>

                                <!-- QR for transfer -->
                                <div id="qrContainer" class="mt-3 text-center d-none">
                                    <p class="text-muted small mb-1">Escanea para transferir</p>
                                    <img id="qrImage" src="" alt="QR Transferencia" style="max-width:180px; border-radius:8px; border:1px solid #dee2e6;">
                                </div>

                                <!-- Proof of payment -->
                                <div id="comprobanteContainer" class="mt-3 d-none">
                                    <label class="form-label small fw-semibold">
                                        <i class="bi bi-paperclip me-1"></i>Comprobante de transferencia
                                    </label>
                                    <input type="file" id="comprobantePago" class="form-control form-control-sm" accept="image/*">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between gap-2">
                    <button class="btn btn-outline-secondary" id="btnVolverCliente">
                        <i class="bi bi-arrow-left me-1"></i>Volver a Cliente
                    </button>
                    <button class="btn btn-success btn-lg px-5" id="btnGenerarFactura">
                        <i class="bi bi-receipt-cutoff me-2"></i>Generar Factura
                    </button>
                </div>
            </div>
        </div>

    </div>

    <!-- Floating total (visible always when products exist) -->
    <div class="floating-total d-none" id="floatingTotal">
        Total: $<span id="floatingAmount">0.00</span>
    </div>

    <!-- Footer -->
    <footer class="mt-5 py-3 bg-dark text-white">
        <div class="container text-center">
            <p class="mb-0 text-white-50">&copy; <%= new Date().getFullYear() %>
                <a href="https://github.com/Alejandro-Moreira" target="_blank" class="fw-bold text-white">Alejandro-Moreira</a>
                — Todos los derechos reservados
            </p>
        </div>
    </footer>

    <!-- ══ Modal: Nuevo Cliente ══ -->
    <div class="modal fade" id="modalNuevoCliente" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus-fill me-2"></i>Nuevo Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formNuevoCliente" novalidate>
                        <div class="mb-3">
                            <label class="form-label">Cédula / RUC</label>
                            <input type="text" class="form-control" id="ncCedula" placeholder="Opcional">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="ncNombre" required>
                            <div class="invalid-feedback">El nombre es requerido.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Dirección</label>
                            <input type="text" class="form-control" id="ncDireccion" placeholder="Opcional">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="text" class="form-control" id="ncTelefono" placeholder="Opcional">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnGuardarNuevoCliente">
                        <i class="bi bi-save me-1"></i>Guardar Cliente
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ Modal: Invoice Preview ══ -->
    <div class="modal fade" id="modalFactura" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Factura Generada</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <iframe id="facturaFrame" style="width:100%; height:80vh; border:none;"></iframe>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" onclick="document.getElementById('facturaFrame').contentWindow.print()">
                        <i class="bi bi-printer me-1"></i>Imprimir
                    </button>
                    <button class="btn btn-success" id="btnNuevaFactura">
                        <i class="bi bi-plus-circle me-1"></i>Nueva Factura
                    </button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/js/billing.js"></script>
</body>
</html>
